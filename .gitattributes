# ---------------------------------------------------------------------------
# Scanner tests with real document filenames (account numbers, names)
# ---------------------------------------------------------------------------
tests/test_scanner.py filter=git-crypt diff=git-crypt

# ---------------------------------------------------------------------------
# Engine modules with hardcoded PII (iCloud paths, names, addresses)
